---
interface Props {
  id: string;
  eyebrow?: string;
  title: string;
}

const { id, eyebrow, title } = Astro.props;
---

<section id={id} class="scroll-mt-20 border-t border-border/50 py-20 sm:py-24">
  <div data-reveal class="mx-auto max-w-6xl px-6">
    <div class="mb-10 max-w-2xl">
      {
        eyebrow && (
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.2em] text-accent">
            {eyebrow}
          </p>
        )
      }
      <h2 class="text-2xl font-semibold tracking-tight text-text sm:text-3xl">
        {title}
      </h2>
    </div>
    <slot />
  </div>
</section>
