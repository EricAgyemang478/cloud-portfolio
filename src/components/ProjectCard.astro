---
import { Icon } from "astro-icon/components";
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusMeta = {
  live: { label: "Live", dot: "bg-accent", class: "border-accent/40 text-accent" },
  building: {
    label: "Building",
    dot: "bg-amber-300",
    class: "border-amber-400/40 text-amber-300",
  },
  planned: {
    label: "Planned",
    dot: "bg-faint",
    class: "border-border-strong text-faint",
  },
} as const;

const status = statusMeta[project.status];
---

<article class="card-glow flex flex-col rounded-xl border border-border bg-surface p-6">
  <div class="mb-2 flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-text">{project.title}</h3>
    <span
      class={`inline-flex shrink-0 items-center gap-1.5 rounded-full border px-2.5 py-0.5 font-mono text-xs ${status.class}`}
    >
      <span class={`h-1.5 w-1.5 rounded-full ${status.dot}`}></span>
      {status.label}
    </span>
  </div>

  <p class="text-sm leading-relaxed text-text/90">{project.tagline}</p>

  <div class="mt-4">
    <p class="mb-1 font-mono text-[11px] uppercase tracking-[0.15em] text-faint">
      Use case
    </p>
    <p class="text-sm leading-relaxed text-muted">{project.problem}</p>
  </div>

  <div class="mt-4">
    <p class="mb-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-faint">
      Architecture
    </p>
    <ul class="space-y-1.5">
      {
        project.architecture.map((point) => (
          <li class="flex gap-2 text-sm leading-relaxed text-muted">
            <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-accent" />
            <span>{point}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-5 flex flex-wrap gap-1.5">
    {
      project.tags.map((t) => (
        <span class="rounded border border-border bg-surface-2 px-2 py-0.5 font-mono text-xs text-faint">
          {t}
        </span>
      ))
    }
  </div>

  <div class="mt-5 flex gap-4 border-t border-border pt-4 text-sm">
    {
      project.repo ? (
        <a
          href={project.repo}
          target="_blank"
          rel="noreferrer"
          class="group inline-flex items-center gap-1.5 font-medium text-text transition hover:text-accent"
        >
          <Icon name="lucide:github" class="size-4" />
          Code
          <Icon
            name="lucide:arrow-up-right"
            class="size-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          />
        </a>
      ) : (
        <span class="text-faint">Repo coming soon</span>
      )
    }
    {
      project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noreferrer"
          class="group inline-flex items-center gap-1.5 font-medium text-text transition hover:text-accent"
        >
          <Icon name="lucide:external-link" class="size-4" />
          Live demo
        </a>
      )
    }
  </div>
</article>
